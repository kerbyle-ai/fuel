# Host nginx: SSL reverse proxy → Docker nginx на localhost:8090
# 1. Замените your-domain.ru на ваш домен
# 2. sudo cp deploy/nginx-host.conf.example /etc/nginx/sites-available/fuel-map
# 3. sudo ln -s /etc/nginx/sites-available/fuel-map /etc/nginx/sites-enabled/
# 4. sudo certbot --nginx -d your-domain.ru
# 5. sudo nginx -t && sudo systemctl reload nginx

upstream fuel_map_app {
    server 127.0.0.1:8090;
    keepalive 8;
}

# Редирект HTTP → HTTPS (после certbot можно оставить certbot-managed блок)
server {
    listen 80;
    listen [::]:80;
    server_name your-domain.ru;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name your-domain.ru;

    # Пути certbot (появятся после: certbot --nginx -d your-domain.ru)
    ssl_certificate     /etc/letsencrypt/live/your-domain.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Безопасность
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    client_max_body_size 1m;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml;

    location / {
        proxy_pass http://fuel_map_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }
}
