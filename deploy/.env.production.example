# =============================================================================
# Fuel Map — production (.env на VPS)
# Скопируйте в корень проекта: cp deploy/.env.production.example .env
# Затем замените ВСЕ значения CHANGE_ME и your-domain.ru
# =============================================================================

# --- PostgreSQL (только внутри Docker, порт наружу НЕ открыт) ---
POSTGRES_USER=fuelmap
# Сгенерируйте: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=fuelmap
# POSTGRES_PORT не используется в prod (db не проброшен на хост)

# Образ PostGIS (при проблемах pull в РФ — зеркало DaoCloud)
POSTGIS_IMAGE=postgis/postgis:16-3.4
# POSTGIS_IMAGE=docker.m.daocloud.io/postgis/postgis:16-3.4

# --- Backend API ---
NODE_ENV=production
API_PORT=3001
# CORS: публичный URL PWA (через запятую, если несколько). Без домена: http://147.45.175.194
ALLOWED_ORIGINS=http://147.45.175.194
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=3600000
DUPLICATE_REPORT_WINDOW_MS=900000

# --- Nginx / Frontend (внутри Docker) ---
# Порт 80 пробрасывается в docker-compose.prod.yml; 8090 — доп. для локальных проверок
NGINX_PORT=8090
VITE_API_URL=/api
# Ссылка на донат — баннер в сайдбаре (см. docs/DONATIONS.md)
VITE_DONATION_URL=https://boosty.to/toplivo

# --- Домен и SSL (host nginx + certbot) ---
DOMAIN=your-domain.ru
CERTBOT_EMAIL=admin@your-domain.ru

# --- Telegram Bot (systemd, не в docker compose) ---
TELEGRAM_BOT_TOKEN=CHANGE_ME_from_BotFather
# API с хоста: nginx на localhost:8090 проксирует /api
API_URL=http://127.0.0.1:8090/api
# Без домена: Cloudflare Quick Tunnel (URL меняется при restart cloudflared-quick)
WEB_APP_URL=https://announced-cap-romantic-committee.trycloudflare.com
# TELEGRAM_NOTIFY_CHANNEL_ID=-1001234567890

# --- Ожидание БД (внутри контейнера api) ---
DB_HOST=db
DB_PORT=5432
DB_WAIT_RETRIES=30
DB_WAIT_INTERVAL=2
