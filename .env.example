# =============================================================================
# Fuel Map — переменные окружения
# Скопируйте: cp .env.example .env
# =============================================================================

# --- PostgreSQL (Docker-сервис db) ---
# Имя пользователя БД
POSTGRES_USER=fuelmap
# Пароль БД (обязательно смените в production!)
POSTGRES_PASSWORD=fuelmap_secret
# Имя базы данных
POSTGRES_DB=fuelmap
# Порт PostgreSQL на хосте (только для локальной разработки)
POSTGRES_PORT=5432

# Образ PostGIS для сервиса db (docker compose)
# По умолчанию — Docker Hub. При ошибках pull (EOF, timeout, reset) в РФ попробуйте зеркало:
# POSTGIS_IMAGE=docker.m.daocloud.io/postgis/postgis:16-3.4
# Либо запустите: .\scripts\docker-pull-images.ps1 — сначала Hub, затем зеркало и retag.
POSTGIS_IMAGE=postgis/postgis:16-3.4

# --- Backend API ---
# Строка подключения (в Docker: хост db; локально: localhost)
DATABASE_URL=postgresql://fuelmap:fuelmap_secret@localhost:5432/fuelmap
# Порт API на хосте
API_PORT=3001
# Режим: development | production
NODE_ENV=development
# CORS (production): через запятую, напр. http://147.45.175.194,https://fuel.example.ru
# ALLOWED_ORIGINS=http://147.45.175.194
# Лимит отчётов на IP за окно (anti-spam)
RATE_LIMIT_MAX=10
# Окно rate limit в миллисекундах (3600000 = 1 час)
RATE_LIMIT_WINDOW_MS=3600000
# Блокировка дубликата station+fuel от одного fingerprint (900000 = 15 мин)
DUPLICATE_REPORT_WINDOW_MS=900000

# --- Telegram Bot (telegram-bot/) ---
# Токен от @BotFather
# TELEGRAM_BOT_TOKEN=
# URL API для бота (в Docker: http://api:3001/api)
# API_URL=http://localhost:3001/api
# URL веб-PWA для /report (без домена: Cloudflare Quick Tunnel, см. deploy/vnc-free-public-url.sh)
# WEB_APP_URL=https://announced-cap-romantic-committee.trycloudflare.com
# Ссылка на Telegram-канал (кнопка в /start)
# TELEGRAM_CHANNEL_URL=https://t.me/toplivo99
# ID канала для уведомлений о новых отчётах (опционально)
# TELEGRAM_NOTIFY_CHANNEL_ID=

# --- Nginx / Frontend ---
# Доп. порт веб-интерфейса на хосте (8090 → http://localhost:8090; порт 80 пробрасывается в docker-compose.prod.yml)
NGINX_PORT=8090
# Базовый URL API для сборки фронтенда (в production через nginx: /api)
VITE_API_URL=/api
# Ссылка на донат (Boosty, CloudTips, Яндекс Чаевые). Пусто — баннер «Поддержать проект» скрыт.
VITE_DONATION_URL=https://boosty.to/toplivo

# --- Ожидание БД (scripts/wait-for-db.sh) ---
# Хост PostgreSQL (в Docker: db)
DB_HOST=db
DB_PORT=5432
# Макс. попыток подключения
DB_WAIT_RETRIES=30
# Интервал между попытками (секунды)
DB_WAIT_INTERVAL=2

# --- Деплой на VPS (справочно, для certbot/nginx на хосте) ---
# Домен сайта, например fuel.example.ru
# DOMAIN=fuel.example.ru
# Email для Let's Encrypt
# CERTBOT_EMAIL=admin@example.ru
