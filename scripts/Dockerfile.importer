# One-shot price importer (Playwright + benzin-price.ru parser)
# Must match playwright version in scripts/package-lock.json (browser + npm package)
FROM mcr.microsoft.com/playwright:v1.61.1-noble

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY tsconfig.json ./
COPY import-benzin-price.ts export-db-dump.ts ./
COPY lib ./lib

ENV NODE_ENV=production

ENTRYPOINT ["npm", "run", "import:benzin-price", "--"]
CMD ["--region", "all", "--delay", "2000", "--match-radius", "250"]
